# DealSpy Bot — Environment Variables
# Copy these to Replit Secrets or Railway Variables
# DO NOT commit this file with real values to GitHub

# ── Required ──────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token-from-botfather
ALLOWED_CHAT_ID=your-personal-chat-id

# ── Channel (for public auto-posting) ─────────────────────
CHANNEL_ID=-1001234567890

# ── Amazon Associates (free, instant signup) ──────────────
AMAZON_PARTNER_TAG=yourstore-21

# ── Amazon PA API (optional, after 3 affiliate sales) ─────
AMAZON_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
AMAZON_SECRET_KEY=your-secret-key-here
